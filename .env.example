# ─────────────────────────────────────────
# FightMind AI — Python Model Service
# Copy this file to .env and fill in values
# ─────────────────────────────────────────

# Google Gemini API (https://aistudio.google.com)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini Model Name (change without touching any code)
GEMINI_MODEL=gemini-2.5-flash

# Groq Free API — fallback when Gemini hits rate limits (console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# TheSportsDB (free — just use "1")
SPORTS_DB_API_KEY=1

# API-Sports fallback (free tier at api-sports.io)
API_SPORTS_KEY=your_api_sports_key_here

# Environment
ENV=development
LOG_LEVEL=INFO
